{
  "extends": "@bilacert/typescript-config/nextjs.json",
  "compilerOptions": {
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
