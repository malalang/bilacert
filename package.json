{
  "name": "bilacert-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --concurrency=1",
    "lint": "pnpm --recursive --workspace-concurrency=1 --if-present run lint",
    "lint:fix": "pnpm --recursive --workspace-concurrency=1 --if-present run lint:fix",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}
