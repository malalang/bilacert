{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "REVALIDATION_SECRET",
    "NEXT_PUBLIC_CLIENT_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ]
    },
    "lint:fix": {
      "dependsOn": [
        "^lint:fix"
      ]
    },
    "format": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    }
  }
}
